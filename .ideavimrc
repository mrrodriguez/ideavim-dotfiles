source ~/astronvim-dotfiles/.vimrc

" Relative line numbers (lua-based neovim config can't be sourced by IdeaVim)
set number
set relativenumber

" Do incremental searching.
set incsearch

" Useful for formatting (but not for SQL)
autocmd FileType * if &filetype != 'sql' | set textwidth=100 | else | set textwidth=0 | endif

" Don't use Ex mode, use Q for formatting.
map Q gq

" See: https://youtrack.jetbrains.com/issue/VIM-186/gq-does-not-reformat-word-wrap-comments#focus=Comments-27-4355985.0-0
nmap gqq :action com.andrewbrookins.idea.wrap.WrapAction<CR>
vmap gq :action com.andrewbrookins.idea.wrap.WrapAction<CR>

" esc in insert & visual mode
inoremap jk <esc>
vnoremap jk <esc>

" See: https://stackoverflow.com/a/27928635/924604
set clipboard+=unnamed
